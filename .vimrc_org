" GENERAL
"
" Disable compatibility with vi for possible unexpected issues.
set nocompatible	
" Enable file type detecton
filetype on
" Enable plugins to detect file types 
filetype plugin on	
" Load ident file for file type detection
filetype indent on	
" Enable syntax highlight
syntax on 		
" Add line numbers on the left-hand side.
set number		

set cursorline
" Cursor line styling
highlight CursorLine cterm=NONE ctermbg=238 guibg=#303030	
" Line number styling
highlight CursorLineNr cterm=NONE ctermbg=238 guibg=#303030	

" SEARCH
"
" Case insensitive search
set ignorecase		
" Only case sensitive for uppercase letters search
set smartcase		
" Highlight serach match
set hlsearch		

" STATUS LINE"
"
" Clear status line when vimrc is reloaded.
set statusline=
" Status line left side.
set statusline+=\ %F\ %M\ %Y\ %R
" Use a divider to separate the left side from the right side.
set statusline+=%=
" Status line right side.
set statusline+=\ ascii:\ %b\ hex:\ 0x%B\ row:\ %l\ col:\ %c\ percent:\ %p%%
" Show the status on the second to last line.
set laststatus=2
